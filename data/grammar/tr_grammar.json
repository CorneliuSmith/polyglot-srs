    {
      "title": "Accusative case (-ı / -i / -u / -ü)",
      "level": "A1",
      "function": "Mark a specific, definite object",
      "source": "contributor",
      "reviewed": true,
      "display_order": 10,
      "explanation": "A DEFINITE direct object takes the accusative: Kitabı okuyorum (I am reading THE book) vs Kitap okuyorum (I read books / a book, indefinite — no suffix). The vowel harmonizes four ways, and final p/ç/t/k soften: kitap → kitabı.",
      "culture_note": "Whether the object is 'definite' decides the suffix — a meaning-driven case system rather than a mechanical one.",
      "references": [
        {
          "title": "Wikipedia: Turkish grammar",
          "url": "https://en.wikipedia.org/wiki/Turkish_grammar"
        },
        {
          "title": "Wikipedia: Turkish grammar — cases",
          "url": "https://en.wikipedia.org/wiki/Turkish_grammar#Cases"
        }
      ],
      "drills": [
        {
          "sentence": "Ben {{answer}} okuyorum.",
          "answer": "kitabı",
          "translation": "I am reading the book.",
          "hint": "kitap → kitabı (definite object)",
          "display_order": 1
        },
        {
          "sentence": "O {{answer}} seviyor.",
          "answer": "çayı",
          "translation": "He/she loves the tea.",
          "hint": "çay + -ı",
          "display_order": 2
        }
      ]
