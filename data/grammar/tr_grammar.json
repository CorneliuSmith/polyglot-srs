          "url": "https://en.wiktionary.org/wiki/-ler#Turkish"
        }
      ],
      "drills": [
        {
          "sentence": "Evde iki {{answer}} var.",
          "answer": "kedi",
          "translation": "There are two cats in the house.",
          "hint": "noun stays SINGULAR after a number",
          "display_order": 1
        },
        {
          "sentence": "{{answer}} bahçede.",
          "answer": "Çocuklar",
          "translation": "The children are in the garden.",
          "hint": "çocuk + back-vowel plural",
