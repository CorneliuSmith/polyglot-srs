    {
      "title": "Past tense (-di)",
      "level": "A2",
      "function": "Say what happened",
      "source": "contributor",
      "reviewed": true,
      "display_order": 1,
      "explanation": "The seen/witnessed past adds -di with four-way vowel harmony and consonant hardening after voiceless sounds (-ti): gitmek → gittim (I went), gelmek → geldi (she came), yapmak → yaptık (we did). Person endings follow: -m, -n, —, -k, -niz, -ler.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Turkish grammar",
          "url": "https://en.wikipedia.org/wiki/Turkish_grammar"
        },
        {
          "title": "Wiktionary: -di (Turkish)",
          "url": "https://en.wiktionary.org/wiki/-di#Turkish"
        }
      ],
      "drills": [
        {
          "sentence": "Dün okula {{answer}}.",
          "answer": "gittim",
          "translation": "Yesterday I went to school.",
          "hint": "git + -ti + -m",
          "display_order": 1
        },
        {
          "sentence": "O eve {{answer}}.",
          "answer": "geldi",
          "translation": "He/she came home.",
          "hint": "gel + -di",
          "display_order": 2
        }
      ]
