    {
      "title": "Question particle (mı / mi / mu / mü)",
      "level": "A1",
      "function": "Turn any statement into a yes/no question",
      "source": "contributor",
      "reviewed": true,
      "display_order": 4,
      "explanation": "Add the particle after the word you are asking about; it is written separately and harmonizes with the last vowel: kitap mı?, öğrenci mi?, doktor mu?, Türk mü? Personal endings attach to the particle: Öğrenci misin? (Are you a student?).",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Turkish grammar",
          "url": "https://en.wikipedia.org/wiki/Turkish_grammar"
        },
        {
          "title": "Wiktionary: mı (Turkish)",
          "url": "https://en.wiktionary.org/wiki/m%C4%B1#Turkish"
        }
      ],
      "drills": [
        {
          "sentence": "Sen öğrenci {{answer}}?",
          "answer": "misin",
          "translation": "Are you a student?",
          "hint": "mi + -sin",
          "display_order": 1
        },
        {
          "sentence": "Bu kitap {{answer}}?",
          "answer": "mı",
          "translation": "Is this a book?",
          "hint": "harmonizes with 'kitap'",
          "display_order": 2
        }
      ]
