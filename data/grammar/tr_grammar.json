          "sentence": "Benim {{answer}} büyük.",
          "answer": "evim",
          "translation": "My house is big.",
          "hint": "ev + -im",
          "display_order": 1
        },
        {
          "sentence": "Senin {{answer}} nerede?",
          "answer": "araban",
          "translation": "Where is your car?",
          "hint": "araba + -n",
          "display_order": 2
