          "answer": "maisons",
          "translation": "The houses are beautiful.",
          "hint": "house, plural",
          "display_order": 2
        },
        {
          "sentence": "J'ai trois {{answer}}.",
          "answer": "sœurs",
          "translation": "I have three sisters.",
          "hint": "sister, plural",
          "display_order": 3
