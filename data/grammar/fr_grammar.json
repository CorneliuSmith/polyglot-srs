    {
      "title": "Negation with ne … pas",
      "level": "A1",
      "function": "Say what is not so",
      "source": "contributor",
      "reviewed": true,
      "display_order": 9,
      "explanation": "Negation wraps the verb in a frame: ne + verb + pas. Je ne parle pas anglais. Before a vowel, ne becomes n': je n'aime pas. After a negation, un/une/des become de: je n'ai pas de chien.",
      "culture_note": "In casual speech the ne often disappears — je parle pas. Learn the full frame first; drop it later like the locals.",
      "references": [
        {
          "title": "Wikipedia: French grammar — negation",
          "url": "https://en.wikipedia.org/wiki/French_grammar"
        },
        {
          "title": "Wiktionary: ne … pas (French)",
          "url": "https://en.wiktionary.org/wiki/ne_..._pas#French"
        }
      ],
      "drills": [
        {
          "sentence": "Je {{answer}} parle pas anglais.",
          "answer": "ne",
          "translation": "I don't speak English.",
          "hint": "the opening half of the frame",
          "display_order": 1
        },
        {
