          "title": "Wiktionary: avoir (French)",
          "url": "https://en.wiktionary.org/wiki/avoir#French"
        },
        {
          "title": "Wikipedia: French conjugation",
          "url": "https://en.wikipedia.org/wiki/French_conjugation"
        }
      ],
