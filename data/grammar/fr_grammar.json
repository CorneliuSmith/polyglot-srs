    {
      "title": "Definite articles (le / la / les)",
      "level": "A1",
      "function": "Point to a specific thing",
      "source": "contributor",
      "reviewed": true,
      "display_order": 3,
      "explanation": "Le before masculine nouns (le livre), la before feminine (la maison), les for any plural (les livres). Before a vowel or silent h, le and la both shrink to l' (l'école). French uses the definite article far more than English — also for general statements: j'aime le café (I like coffee).",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: French articles and determiners",
          "url": "https://en.wikipedia.org/wiki/French_articles_and_determiners"
        },
        {
          "title": "Wikipedia: French grammar",
          "url": "https://en.wikipedia.org/wiki/French_grammar"
        }
      ],
      "drills": [
        {
          "sentence": "{{answer}} maison est grande.",
          "answer": "La",
          "translation": "The house is big.",
          "hint": "feminine singular",
          "display_order": 1,
          "cell": "la"
        },
        {
          "sentence": "{{answer}} livre est nouveau.",
          "answer": "Le",
          "translation": "The book is new.",
          "hint": "masculine singular",
          "display_order": 2,
          "cell": "le"
        },
        {
          "sentence": "{{answer}} enfants jouent dehors.",
          "answer": "Les",
          "translation": "The children are playing outside.",
          "hint": "plural",
          "display_order": 3,
          "cell": "les"
        },
        {
          "sentence": "{{answer}} café est chaud.",
          "answer": "Le",
          "translation": "The coffee is hot.",
          "hint": "masculine singular",
          "display_order": 4,
          "cell": "le"
        },
        {
          "sentence": "{{answer}} porte est ouverte.",
          "answer": "La",
          "translation": "The door is open.",
          "hint": "feminine singular",
          "display_order": 5,
          "cell": "la"
        },
        {
          "sentence": "{{answer}} chiens sont dans le jardin.",
          "answer": "Les",
          "translation": "The dogs are in the garden.",
          "hint": "plural",
          "display_order": 6,
          "cell": "les"
        }
      ],
      "paradigm": [
        "le",
        "la",
        "les"
      ]
    },
    {
      "title": "Indefinite articles (un / une / des)",
      "level": "A1",
      "function": "Mention something for the first time",
      "source": "contributor",
      "reviewed": true,
      "display_order": 4,
      "explanation": "Un before masculine nouns (un chien), une before feminine (une maison), and — unlike English — a plural indefinite des (des amis, 'some friends'). Des is required where English just drops the article: j'ai des questions.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: French articles and determiners",
          "url": "https://en.wikipedia.org/wiki/French_articles_and_determiners"
        },
        {
          "title": "Wiktionary: un (French)",
          "url": "https://en.wiktionary.org/wiki/un#French"
        }
      ],
      "drills": [
        {
          "sentence": "J'ai {{answer}} chien.",
          "answer": "un",
          "translation": "I have a dog.",
          "hint": "masculine",
          "display_order": 1,
          "cell": "un"
        },
        {
          "sentence": "C'est {{answer}} grande maison.",
          "answer": "une",
          "translation": "It is a big house.",
          "hint": "feminine",
          "display_order": 2,
          "cell": "une"
        },
        {
          "sentence": "Il a {{answer}} idée.",
          "answer": "une",
          "translation": "He has an idea.",
          "hint": "idée is feminine",
          "display_order": 3,
          "cell": "une"
        },
        {
          "sentence": "Nous avons {{answer}} amis à Lyon.",
          "answer": "des",
          "translation": "We have (some) friends in Lyon.",
          "hint": "plural indefinite",
          "display_order": 4,
          "cell": "des"
        },
        {
          "sentence": "C'est {{answer}} bon livre.",
          "answer": "un",
          "translation": "It is a good book.",
          "hint": "masculine",
          "display_order": 5,
          "cell": "un"
        },
        {
          "sentence": "Elle achète {{answer}} pommes.",
          "answer": "des",
          "translation": "She is buying (some) apples.",
          "hint": "plural indefinite",
          "display_order": 6,
          "cell": "des"
        }
      ],
      "paradigm": [
        "un",
        "une",
        "des"
      ]
    },
    {
