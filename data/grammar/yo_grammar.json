    {
      "title": "Object pronouns",
      "level": "A2",
      "function": "Say who receives the action",
      "source": "contributor",
      "reviewed": true,
      "display_order": 3,
      "explanation": "Object pronouns follow the verb and copy its final vowel's tone pattern: rí mi (see me), rí ẹ (see you), rí i (see him/her/it — vowel echo), rí wa (see us), rí yín (see you all), rí wọn (see them). Mo rí i (I saw him).",
      "culture_note": "",
