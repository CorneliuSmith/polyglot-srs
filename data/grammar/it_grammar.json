          "answer": "La",
          "translation": "The house is big.",
          "hint": "feminine singular",
          "display_order": 1
        },
        {
          "sentence": "{{answer}} libro è nuovo.",
          "answer": "Il",
          "translation": "The book is new.",
          "hint": "masculine singular",
          "display_order": 2
        },
        {
          "sentence": "{{answer}} bambini giocano fuori.",
          "answer": "I",
          "translation": "The children are playing outside.",
          "hint": "masculine plural",
          "display_order": 3
        },
        {
          "sentence": "{{answer}} caffè è caldo.",
          "answer": "Il",
          "translation": "The coffee is hot.",
          "hint": "masculine singular",
          "display_order": 4
        },
        {
          "sentence": "{{answer}} ragazze sono simpatiche.",
          "answer": "Le",
          "translation": "The girls are nice.",
          "hint": "feminine plural",
          "display_order": 5
        },
        {
          "sentence": "{{answer}} zaino è pesante.",
          "answer": "Lo",
          "translation": "The backpack is heavy.",
          "hint": "masculine before z-",
          "display_order": 6
        }
      ]
