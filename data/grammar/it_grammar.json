    {
      "title": "Avere — present (ho fame)",
      "level": "A1",
      "function": "Say what you have — and how you feel",
      "source": "contributor",
      "reviewed": true,
      "display_order": 6,
      "explanation": "Avere (to have): ho, hai, ha, abbiamo, avete, hanno — the h is silent, written only to distinguish from other words. Italian HAS its states: ho fame (I'm hungry), ho sete (thirsty), ho vent'anni (I'm twenty), hai ragione (you're right).",
      "culture_note": "",
      "references": [
        {
          "title": "Wiktionary: avere (Italian)",
          "url": "https://en.wiktionary.org/wiki/avere#Italian"
        },
        {
          "title": "Wikipedia: Italian conjugation",
          "url": "https://en.wikipedia.org/wiki/Italian_conjugation"
        }
      ],
      "drills": [
        {
          "sentence": "Io {{answer}} vent'anni.",
          "answer": "ho",
          "translation": "I am twenty years old.",
          "hint": "to have, I",
          "display_order": 1
        },
        {
          "sentence": "Tu {{answer}} fame?",
          "answer": "hai",
          "translation": "Are you hungry?",
          "hint": "to have, you (informal)",
          "display_order": 2
        },
        {
