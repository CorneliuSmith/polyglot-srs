{
  "lists": [
    {
      "level": "A1",
      "title": "Italian A1 Grammar Path",
      "description": "A1 grammar in communicative order: pronouns (and when to drop them), noun gender and number, both article families, essere and avere, the three conjugations, negation, c'è / ci sono, questions, and adjective agreement."
