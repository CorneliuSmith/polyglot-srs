  "points": [
    {
      "title": "Subject pronouns (io, tu, lui…)",
      "level": "A1",
      "function": "Say who you are talking about — when it needs saying",
      "source": "contributor",
      "reviewed": true,
      "display_order": 1,
      "explanation": "Io (I), tu (you, informal), lui/lei (he/she), Lei (you, formal), noi (we), voi (you all), loro (they). The verb ending already says who — so Italian normally DROPS the pronoun (parlo italiano = I speak Italian) and uses it only for emphasis or contrast.",
      "culture_note": "Formal 'you' is Lei — grammatically 'she', even for a man. Waiters, officials, strangers: Lei.",
      "references": [
        {
          "title": "Wikipedia: Italian grammar — pronouns",
          "url": "https://en.wikipedia.org/wiki/Italian_grammar"
        },
        {
          "title": "Wikipedia: Pro-drop language",
          "url": "https://en.wikipedia.org/wiki/Pro-drop_language"
        }
      ],
      "drills": [
        {
          "sentence": "{{answer}} sono di Roma.",
          "answer": "Io",
          "translation": "I am from Rome.",
          "hint": "I",
          "display_order": 1
        },
        {
          "sentence": "{{answer}} sei il mio migliore amico.",
          "answer": "Tu",
          "translation": "You are my best friend.",
          "hint": "you — informal",
          "display_order": 2
        },
        {
          "sentence": "{{answer}} è mia sorella.",
          "answer": "Lei",
          "translation": "She is my sister.",
          "hint": "she",
          "display_order": 3
        },
        {
          "sentence": "{{answer}} siamo studenti.",
          "answer": "Noi",
          "translation": "We are students.",
          "hint": "we",
          "display_order": 4
        },
        {
          "sentence": "{{answer}} sono i miei genitori.",
          "answer": "Loro",
          "translation": "They are my parents.",
          "hint": "they",
          "display_order": 5
        },
        {
          "sentence": "{{answer}} è il mio professore.",
          "answer": "Lui",
          "translation": "He is my teacher.",
          "hint": "he",
          "display_order": 6
        }
      ]
    },
    {
      "title": "Gender and number of nouns",
      "level": "A1",
      "function": "Name people and things, one or many",
      "source": "contributor",
      "reviewed": true,
      "display_order": 2,
      "explanation": "Most nouns wear their gender openly: -o masculine (libro), -a feminine (casa). Plurals swap the vowel: -o → -i (libri), -a → -e (case). Nouns in -e can be either gender (il fiore, la notte) and pluralize to -i.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Italian grammar — nouns",
          "url": "https://en.wikipedia.org/wiki/Italian_grammar"
        },
        {
          "title": "Wikipedia: Grammatical gender",
          "url": "https://en.wikipedia.org/wiki/Grammatical_gender"
        }
      ],
      "drills": [
        {
          "sentence": "Ho due {{answer}}.",
          "answer": "libri",
          "translation": "I have two books.",
          "hint": "book, plural",
          "display_order": 1
        },
        {
          "sentence": "Le {{answer}} sono belle.",
          "answer": "case",
          "translation": "The houses are beautiful.",
          "hint": "house, plural",
          "display_order": 2
        },
        {
          "sentence": "Ho tre {{answer}}.",
          "answer": "sorelle",
          "translation": "I have three sisters.",
          "hint": "sister, plural",
          "display_order": 3
        },
        {
          "sentence": "I {{answer}} sono grandi.",
          "answer": "giardini",
          "translation": "The gardens are big.",
          "hint": "garden, plural",
          "display_order": 4
        },
        {
          "sentence": "Ho due {{answer}} a casa.",
          "answer": "gatti",
          "translation": "I have two cats at home.",
          "hint": "cat, plural",
          "display_order": 5
        },
        {
          "sentence": "Le {{answer}} sono nuove.",
          "answer": "macchine",
          "translation": "The cars are new.",
          "hint": "car, plural",
          "display_order": 6
        }
      ]
    },
    {
      "title": "Definite articles (il / la / i / le)",
      "level": "A1",
      "function": "Point to a specific thing",
      "source": "contributor",
      "reviewed": true,
      "display_order": 3,
      "explanation": "Il for masculine (il libro), la for feminine (la casa); plurals i and le. Before s+consonant or z, masculine takes lo (lo zaino, plural gli). Before vowels, l' (l'amico). Italian loves its articles — even before possessives: la mia casa.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Italian grammar — articles",
          "url": "https://en.wikipedia.org/wiki/Italian_grammar"
        },
        {
          "title": "Wiktionary: il (Italian)",
          "url": "https://en.wiktionary.org/wiki/il#Italian"
        }
      ],
      "drills": [
        {
