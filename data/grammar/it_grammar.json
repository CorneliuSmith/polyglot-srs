          "hint": "to be, you (plural)",
          "display_order": 5
        },
        {
          "sentence": "Loro {{answer}} a casa.",
          "answer": "sono",
          "translation": "They are at home.",
          "hint": "to be, they",
          "display_order": 6
        }
      ]
