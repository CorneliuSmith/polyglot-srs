    {
      "title": "Indefinite articles (un / una / uno)",
      "level": "A1",
      "function": "Mention something for the first time",
      "source": "contributor",
      "reviewed": true,
      "display_order": 4,
      "explanation": "Un for masculine (un cane), una for feminine (una casa), uno before s+consonant or z (uno zaino), un' before feminine vowels (un'idea). No plural form — 'some' is expressed other ways later.",
