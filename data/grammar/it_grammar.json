    {
      "title": "Gender and number of nouns",
      "level": "A1",
      "function": "Name people and things, one or many",
      "source": "contributor",
      "reviewed": true,
      "display_order": 2,
      "explanation": "Most nouns wear their gender openly: -o masculine (libro), -a feminine (casa). Plurals swap the vowel: -o → -i (libri), -a → -e (case). Nouns in -e can be either gender (il fiore, la notte) and pluralize to -i.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Italian grammar — nouns",
          "url": "https://en.wikipedia.org/wiki/Italian_grammar"
        },
        {
          "title": "Wikipedia: Grammatical gender",
          "url": "https://en.wikipedia.org/wiki/Grammatical_gender"
        }
      ],
      "drills": [
        {
          "sentence": "Ho due {{answer}}.",
          "answer": "libri",
          "translation": "I have two books.",
          "hint": "book, plural",
          "display_order": 1,
          "cell": "masculine"
        },
        {
          "sentence": "Le {{answer}} sono belle.",
          "answer": "case",
          "translation": "The houses are beautiful.",
          "hint": "house, plural",
          "display_order": 2,
          "cell": "feminine"
        },
        {
          "sentence": "Ho tre {{answer}}.",
          "answer": "sorelle",
          "translation": "I have three sisters.",
          "hint": "sister, plural",
          "display_order": 3,
          "cell": "feminine"
        },
        {
          "sentence": "I {{answer}} sono grandi.",
          "answer": "giardini",
          "translation": "The gardens are big.",
          "hint": "garden, plural",
          "display_order": 4,
          "cell": "masculine"
        },
        {
          "sentence": "Ho due {{answer}} a casa.",
          "answer": "gatti",
          "translation": "I have two cats at home.",
          "hint": "cat, plural",
          "display_order": 5,
          "cell": "masculine"
        },
        {
          "sentence": "Le {{answer}} sono nuove.",
          "answer": "macchine",
          "translation": "The cars are new.",
          "hint": "car, plural",
          "display_order": 6,
          "cell": "feminine"
        }
      ],
      "paradigm": [
        "masculine",
        "feminine"
      ]
    },
    {
      "title": "Definite articles (il / la / i / le)",
      "level": "A1",
      "function": "Point to a specific thing",
      "source": "contributor",
      "reviewed": true,
      "display_order": 3,
      "explanation": "Il for masculine (il libro), la for feminine (la casa); plurals i and le. Before s+consonant or z, masculine takes lo (lo zaino, plural gli). Before vowels, l' (l'amico). Italian loves its articles — even before possessives: la mia casa.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Italian grammar — articles",
          "url": "https://en.wikipedia.org/wiki/Italian_grammar"
        },
        {
          "title": "Wiktionary: il (Italian)",
          "url": "https://en.wiktionary.org/wiki/il#Italian"
        }
      ],
      "drills": [
