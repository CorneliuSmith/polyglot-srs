    {
      "title": "Essere — present (sono, sei, è…)",
      "level": "A1",
      "function": "Say who or what someone is",
      "source": "contributor",
      "reviewed": true,
      "display_order": 5,
      "explanation": "Essere (to be): sono, sei, è, siamo, siete, sono. Note sono doubles for 'I am' and 'they are' — context (or a pronoun) tells them apart. Professions drop the article: sono studente.",
      "culture_note": "",
      "references": [
        {
          "title": "Wiktionary: essere (Italian)",
          "url": "https://en.wiktionary.org/wiki/essere#Italian"
        },
        {
          "title": "Wikipedia: Italian conjugation",
          "url": "https://en.wikipedia.org/wiki/Italian_conjugation"
        }
      ],
      "drills": [
        {
          "sentence": "Io {{answer}} studente.",
          "answer": "sono",
          "translation": "I am a student.",
          "hint": "to be, I",
          "display_order": 1
        },
        {
          "sentence": "Tu {{answer}} molto alto.",
          "answer": "sei",
          "translation": "You are very tall.",
          "hint": "to be, you (informal)",
          "display_order": 2
        },
        {
          "sentence": "Lei {{answer}} professoressa.",
          "answer": "è",
          "translation": "She is a teacher.",
          "hint": "to be, she",
          "display_order": 3
        },
        {
          "sentence": "Noi {{answer}} amici.",
          "answer": "siamo",
          "translation": "We are friends.",
          "hint": "to be, we",
          "display_order": 4
        },
        {
          "sentence": "Voi {{answer}} italiani?",
