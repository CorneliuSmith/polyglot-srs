    {
      "title": "Verb second (V2) word order",
      "level": "A1",
      "function": "Build German sentences in the German order",
      "source": "contributor",
      "reviewed": true,
      "display_order": 8,
      "explanation": "The conjugated verb is ALWAYS the second element of a statement. Start with anything else — time, place — and the subject slides behind the verb: Ich lerne heute Deutsch → Heute lerne ich Deutsch. The verb stays put; everything else dances around it.",
      "culture_note": "V2 is the single most German thing about German — internalize it at A1 and everything later gets easier.",
      "references": [
        {
          "title": "Wikipedia: V2 word order",
          "url": "https://en.wikipedia.org/wiki/V2_word_order"
        },
        {
          "title": "Wikipedia: German sentence structure",
          "url": "https://en.wikipedia.org/wiki/German_sentence_structure"
        }
      ],
      "drills": [
        {
          "sentence": "Heute {{answer}} ich Deutsch.",
          "answer": "lerne",
          "translation": "Today I am learning German.",
          "hint": "to learn, I — verb stays second",
          "display_order": 1
        },
        {
          "sentence": "Morgen {{answer}} wir nach Berlin.",
          "answer": "fahren",
          "translation": "Tomorrow we are travelling to Berlin.",
          "hint": "to travel, we — verb stays second",
          "display_order": 2
        },
        {
          "sentence": "Am Montag {{answer}} er Fußball.",
          "answer": "spielt",
          "translation": "On Monday he plays football.",
          "hint": "to play, he — verb stays second",
          "display_order": 3
        },
        {
          "sentence": "Jetzt {{answer}} sie Kaffee.",
          "answer": "trinkt",
          "translation": "Now she is drinking coffee.",
          "hint": "to drink, she — verb stays second",
          "display_order": 4
        },
        {
          "sentence": "Abends {{answer}} ich Musik.",
          "answer": "höre",
          "translation": "In the evenings I listen to music.",
          "hint": "to listen, I — verb stays second",
          "display_order": 5
        },
        {
          "sentence": "Hier {{answer}} meine Schwester.",
          "answer": "wohnt",
          "translation": "My sister lives here.",
          "hint": "to live, she — verb stays second",
          "display_order": 6
        }
      ]
    },
    {
      "title": "Negation with nicht and kein",
      "level": "A1",
      "function": "Say what is not so",
      "source": "contributor",
      "reviewed": true,
      "display_order": 9,
      "explanation": "Two negators with a clean split: kein negates nouns with ein or no article (ich habe kein Auto, keine Zeit); nicht negates everything else — verbs, adjectives, definite nouns (das ist nicht richtig, ich wohne nicht hier). Kein agrees like ein: kein/keine.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: German grammar — negation",
          "url": "https://en.wikipedia.org/wiki/German_grammar"
        },
        {
          "title": "Wiktionary: kein (German)",
          "url": "https://en.wiktionary.org/wiki/kein#German"
        }
      ],
      "drills": [
        {
          "sentence": "Ich habe {{answer}} Auto.",
          "answer": "kein",
          "translation": "I don't have a car.",
          "hint": "noun negator, neuter",
          "display_order": 1
        },
        {
          "sentence": "Sie hat {{answer}} Zeit.",
          "answer": "keine",
          "translation": "She has no time.",
          "hint": "noun negator, feminine",
          "display_order": 2
        },
        {
          "sentence": "Das ist {{answer}} richtig.",
          "answer": "nicht",
          "translation": "That is not right.",
          "hint": "negates an adjective",
          "display_order": 3
        },
        {
          "sentence": "Wir wohnen {{answer}} in Berlin.",
          "answer": "nicht",
          "translation": "We don't live in Berlin.",
          "hint": "negates the verb phrase",
          "display_order": 4
        },
        {
          "sentence": "Ich habe {{answer}} Geld.",
          "answer": "kein",
          "translation": "I have no money.",
          "hint": "noun negator, neuter",
          "display_order": 5
        },
        {
          "sentence": "Er ist {{answer}} müde.",
          "answer": "nicht",
          "translation": "He is not tired.",
          "hint": "negates an adjective",
          "display_order": 6
        }
      ]
    },
