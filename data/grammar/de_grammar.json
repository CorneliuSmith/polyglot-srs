{
  "lists": [
    {
      "level": "A1",
      "title": "German A1 Grammar Path",
      "description": "A1 grammar in communicative order: pronouns, the three genders, both article families, sein and haben, the present tense, verb-second word order, negation with nicht and kein, es gibt, questions, and the first case (accusative)."
    }
