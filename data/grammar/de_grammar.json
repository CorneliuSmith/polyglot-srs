    {
      "title": "Haben — present (ich habe Hunger)",
      "level": "A1",
      "function": "Say what you have — and how you feel",
      "source": "contributor",
      "reviewed": true,
      "display_order": 6,
      "explanation": "Haben (to have): ich habe, du hast, er/sie hat, wir haben, ihr habt, sie/Sie haben. Like French, German HAS its states: Hunger haben (be hungry), Durst haben (be thirsty), Recht haben (be right), Glück haben (be lucky).",
      "culture_note": "",
      "references": [
        {
          "title": "Wiktionary: haben (German)",
          "url": "https://en.wiktionary.org/wiki/haben#German"
        },
        {
          "title": "Wikipedia: German conjugation",
          "url": "https://en.wikipedia.org/wiki/German_conjugation"
        }
      ],
      "drills": [
        {
          "sentence": "Ich {{answer}} Hunger.",
          "answer": "habe",
          "translation": "I am hungry.",
          "hint": "to have, I",
          "display_order": 1
        },
        {
          "sentence": "Du {{answer}} Recht.",
          "answer": "hast",
          "translation": "You are right.",
          "hint": "to have, you (informal)",
          "display_order": 2
        },
        {
          "sentence": "Sie {{answer}} eine Katze.",
          "answer": "hat",
          "translation": "She has a cat.",
          "hint": "to have, she",
          "display_order": 3
        },
        {
          "sentence": "Wir {{answer}} Zeit.",
          "answer": "haben",
          "translation": "We have time.",
          "hint": "to have, we",
          "display_order": 4
        },
        {
          "sentence": "Ihr {{answer}} Glück.",
          "answer": "habt",
          "translation": "You (all) are lucky.",
          "hint": "to have, you (plural)",
          "display_order": 5
        },
