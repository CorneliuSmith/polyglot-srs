    {
      "title": "Accusative case (den / einen)",
      "level": "A1",
      "function": "Mark the direct object",
      "source": "contributor",
      "reviewed": true,
      "display_order": 12,
      "explanation": "The direct object takes the accusative — and only MASCULINE articles change: der → den, ein → einen (ich sehe den Mann, ich habe einen Hund). Feminine, neuter, and plural look identical to the nominative: ich lese das Buch, ich sehe die Frau.",
      "culture_note": "One changing gender is a gentle introduction — dative and genitive wait politely at A2.",
      "references": [
        {
          "title": "Wikipedia: German declension — accusative",
          "url": "https://en.wikipedia.org/wiki/German_declension"
        },
        {
          "title": "Wikipedia: Accusative case",
          "url": "https://en.wikipedia.org/wiki/Accusative_case"
        }
      ],
      "drills": [
        {
          "sentence": "Ich sehe {{answer}} Mann.",
          "answer": "den",
          "translation": "I see the man.",
          "hint": "definite article — masculine object",
          "display_order": 1
        },
        {
          "sentence": "Sie liest {{answer}} Buch.",
          "answer": "das",
          "translation": "She is reading the book.",
          "hint": "neuter — unchanged as object",
          "display_order": 2
        },
        {
          "sentence": "Wir kaufen {{answer}} Tisch.",
          "answer": "einen",
          "translation": "We are buying a table.",
          "hint": "indefinite article — masculine object",
          "display_order": 3
        },
        {
