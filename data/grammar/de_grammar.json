  "points": [
    {
      "title": "Subject pronouns (ich, du, er…)",
      "level": "A1",
      "function": "Say who you are talking about",
      "source": "contributor",
      "reviewed": true,
      "display_order": 1,
      "explanation": "The subject pronouns are ich (I), du (you, informal), er/sie/es (he/she/it), wir (we), ihr (you all, informal), sie (they) and Sie (you, formal — always capitalized). Formal Sie takes the same verb form as 'they'.",
      "culture_note": "Germans switch from Sie to du more slowly than you might expect — wait for the offer ('Wir können uns duzen').",
      "references": [
        {
          "title": "Wikipedia: German pronouns",
          "url": "https://en.wikipedia.org/wiki/German_pronouns"
        },
        {
          "title": "Wikipedia: German grammar",
          "url": "https://en.wikipedia.org/wiki/German_grammar"
        }
      ],
      "drills": [
        {
          "sentence": "{{answer}} wohne in Berlin.",
          "answer": "Ich",
          "translation": "I live in Berlin.",
          "hint": "I",
          "display_order": 1
        },
        {
          "sentence": "{{answer}} bist mein Freund.",
          "answer": "Du",
          "translation": "You are my friend.",
          "hint": "you — informal",
          "display_order": 2
        },
        {
          "sentence": "{{answer}} ist meine Schwester.",
          "answer": "Sie",
          "translation": "She is my sister.",
          "hint": "she",
          "display_order": 3
        },
        {
          "sentence": "{{answer}} sind Studenten.",
          "answer": "Wir",
          "translation": "We are students.",
          "hint": "we",
          "display_order": 4
        },
        {
          "sentence": "{{answer}} seid sehr nett.",
          "answer": "Ihr",
          "translation": "You (all) are very nice.",
          "hint": "you — plural informal",
          "display_order": 5
        },
        {
          "sentence": "{{answer}} arbeitet bei einer Bank.",
          "answer": "Er",
          "translation": "He works at a bank.",
          "hint": "he",
          "display_order": 6
        }
      ]
    },
    {
      "title": "Gender and number of nouns",
      "level": "A1",
      "function": "Name people and things, one or many",
      "source": "contributor",
      "reviewed": true,
      "display_order": 2,
      "explanation": "German nouns have THREE genders — masculine (der Mann), feminine (die Frau), neuter (das Kind) — and are always capitalized. Plurals form several ways (-e, -er, -en, -s, umlaut: Buch → Bücher, Haus → Häuser), so learn each noun with its gender AND its plural.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: German nouns",
          "url": "https://en.wikipedia.org/wiki/German_nouns"
        },
        {
          "title": "Wikipedia: Grammatical gender",
          "url": "https://en.wikipedia.org/wiki/Grammatical_gender"
        }
      ],
      "drills": [
        {
          "sentence": "Ich habe zwei {{answer}}.",
          "answer": "Bücher",
          "translation": "I have two books.",
          "hint": "book, plural (umlaut)",
          "display_order": 1
        },
        {
          "sentence": "Die {{answer}} sind schön.",
          "answer": "Häuser",
          "translation": "The houses are beautiful.",
          "hint": "house, plural (umlaut)",
          "display_order": 2
        },
        {
          "sentence": "Ich habe drei {{answer}}.",
          "answer": "Schwestern",
          "translation": "I have three sisters.",
          "hint": "sister, plural",
          "display_order": 3
        },
        {
          "sentence": "Die {{answer}} spielen im Garten.",
