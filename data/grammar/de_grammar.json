    {
      "title": "Sein — present (ich bin, du bist…)",
      "level": "A1",
      "function": "Say who or what someone is",
      "source": "contributor",
      "reviewed": true,
      "display_order": 5,
      "explanation": "Sein (to be) is completely irregular: ich bin, du bist, er/sie/es ist, wir sind, ihr seid, sie/Sie sind. Professions and nationalities take no article: sie ist Lehrerin, ich bin Deutscher.",
      "culture_note": "",
      "references": [
        {
          "title": "Wiktionary: sein (German)",
          "url": "https://en.wiktionary.org/wiki/sein#German"
        },
        {
          "title": "Wikipedia: German conjugation",
          "url": "https://en.wikipedia.org/wiki/German_conjugation"
        }
      ],
      "drills": [
        {
          "sentence": "Ich {{answer}} Student.",
          "answer": "bin",
          "translation": "I am a student.",
          "hint": "to be, I",
          "display_order": 1
        },
        {
          "sentence": "Du {{answer}} sehr groß.",
          "answer": "bist",
          "translation": "You are very tall.",
          "hint": "to be, you (informal)",
          "display_order": 2
        },
        {
          "sentence": "Sie {{answer}} Lehrerin.",
          "answer": "ist",
          "translation": "She is a teacher.",
          "hint": "to be, she",
          "display_order": 3
        },
        {
          "sentence": "Wir {{answer}} Freunde.",
          "answer": "sind",
          "translation": "We are friends.",
          "hint": "to be, we",
          "display_order": 4
        },
        {
          "sentence": "Ihr {{answer}} müde.",
          "answer": "seid",
          "translation": "You (all) are tired.",
          "hint": "to be, you (plural)",
          "display_order": 5
        },
        {
          "sentence": "Die Kinder {{answer}} im Garten.",
          "answer": "sind",
          "translation": "The children are in the garden.",
          "hint": "to be, they",
          "display_order": 6
        }
      ]
