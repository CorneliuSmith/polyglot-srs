    {
      "title": "Roots and patterns (ك ت ب)",
      "level": "A1",
      "function": "See how Arabic words are built",
      "source": "contributor",
      "reviewed": true,
      "display_order": 7,
      "explanation": "Most Arabic words grow from a three-consonant root poured into patterns. From ك-ت-ب (writing): كتاب (book), كاتب (writer — the 'doer' pattern), مكتب (office/desk — the 'place' pattern), مكتبة (library). Learn to spot the root and unknown words start explaining themselves.",
      "culture_note": "Arabic dictionaries are organized by root, not by spelling — to look up مكتبة you go to ك-ت-ب.",
      "references": [
        {
          "title": "Wikipedia: Semitic root",
          "url": "https://en.wikipedia.org/wiki/Semitic_root"
        },
        {
          "title": "Wikipedia: Arabic grammar — derivation",
          "url": "https://en.wikipedia.org/wiki/Arabic_grammar"
        }
      ],
      "drills": [
        {
          "sentence": "هذا {{answer}}.",
          "answer": "كتاب",
          "translation": "This is a book.",
          "hint": "the thing you read — root k-t-b",
          "display_order": 1,
          "transliteration": "hādhā ___"
        },
        {
          "sentence": "هو {{answer}}.",
          "answer": "كاتب",
          "translation": "He is a writer.",
          "hint": "the doer pattern of k-t-b",
          "display_order": 2,
          "transliteration": "huwa ___"
        },
        {
          "sentence": "{{answer}} قريب من البيت.",
          "answer": "المكتب",
          "translation": "The office is near the house.",
          "hint": "the place pattern of k-t-b + the article",
