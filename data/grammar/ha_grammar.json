    {
      "title": "Relative clauses (wanda, wadda, waɗanda)",
      "level": "B1",
      "function": "Describe with 'the one who/that'",
      "source": "contributor",
      "reviewed": true,
      "display_order": 2,
      "explanation": "Wanda (m), wadda (f), waɗanda (pl) introduce relatives: mutumin da ya zo — or with the full pronoun: wanda ya zo (the one who came), motar da na saya (the car that I bought). In relatives the continuous switches to -ke: wanda yake aiki (who is working).",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Hausa language — grammar",
          "url": "https://en.wikipedia.org/wiki/Hausa_language#Grammar"
        }
      ],
      "drills": [
        {
          "sentence": "Mutumin {{answer}} ya zo malami ne.",
          "answer": "da",
          "translation": "The man who came is a teacher.",
          "hint": "relative 'da'",
          "display_order": 1
        },
        {
          "sentence": "{{answer}} ya zo malami ne.",
          "answer": "Wanda",
          "translation": "The one who came is a teacher.",
          "hint": "m. relative pronoun",
          "display_order": 2
        }
      ]
    },
