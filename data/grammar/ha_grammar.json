          "sentence": "{{answer}} yana nan.",
          "answer": "Littafina",
          "translation": "My book is here.",
          "hint": "littafi + -na",
          "display_order": 1
        },
        {
          "sentence": "{{answer}} sabuwa ce.",
          "answer": "Motata",
          "translation": "My car is new.",
          "hint": "mota + -ta ('my', feminine noun)",
          "display_order": 2
        }
      ]
