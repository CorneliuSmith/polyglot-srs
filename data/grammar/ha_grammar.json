    {
      "title": "Imperative and don't (kada)",
      "level": "A2",
      "function": "Give commands and warnings",
      "source": "contributor",
      "reviewed": true,
      "display_order": 4,
      "explanation": "The bare verb commands: Zo! (Come!), Tafi! (Go!), Ci abinci! (Eat!). The negative command uses kada + subjunctive pronoun: Kada ka tafi! (Don't go!), Kada ku manta! (Don't (you all) forget!).",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Hausa language — grammar",
          "url": "https://en.wikipedia.org/wiki/Hausa_language#Grammar"
        }
      ],
      "drills": [
        {
          "sentence": "{{answer}} nan!",
          "answer": "Zo",
          "translation": "Come here!",
          "hint": "bare-verb command",
          "display_order": 1
        },
        {
          "sentence": "{{answer}} ka tafi!",
          "answer": "Kada",
          "translation": "Don't go!",
          "hint": "negative-command word",
          "display_order": 2
        }
      ]
    },
