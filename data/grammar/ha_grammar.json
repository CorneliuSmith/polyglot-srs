      "references": [
        {
          "title": "Wikipedia: Hausa language — grammar",
          "url": "https://en.wikipedia.org/wiki/Hausa_language#Grammar"
        }
      ],
      "drills": [
        {
          "sentence": "Ya ce {{answer}} zai zo.",
          "answer": "cewa",
          "translation": "He said that he would come.",
          "hint": "'that' complementizer",
          "display_order": 1
        },
        {
          "sentence": "Na ji {{answer}} sun tafi.",
