    {
      "title": "Subjunctive (ka tafi, mu je…)",
      "level": "B1",
      "function": "Express wishes, purposes, and suggestions",
      "source": "contributor",
      "reviewed": true,
      "display_order": 1,
      "explanation": "The plain (subjunctive) pronoun set — in, ka/ki, ya, ta, mu, ku, su — follows wanting and purpose: Ina so ka zo (I want you to come), Bari mu je (Let's go), Ya kamata ka yi aiki (You should work).",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Hausa language — grammar",
          "url": "https://en.wikipedia.org/wiki/Hausa_language#Grammar"
        }
      ],
      "drills": [
        {
          "sentence": "Ina so {{answer}} zo.",
          "answer": "ka",
          "translation": "I want you to come.",
          "hint": "subjunctive 'you'",
          "display_order": 1
        },
        {
          "sentence": "Bari {{answer}} je kasuwa.",
          "answer": "mu",
          "translation": "Let's go to the market.",
          "hint": "subjunctive 'we' after bari",
          "display_order": 2
        }
      ]
