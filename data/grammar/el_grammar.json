    {
      "title": "The accusative object (τον / την / το)",
      "level": "A1",
      "function": "Mark what the action lands on",
      "source": "contributor",
      "reviewed": true,
      "display_order": 8,
      "explanation": "Objects take the accusative — mostly visible in the article: ο → τον, η → την, το stays το. Masculine nouns also drop the final -ς: ο δρόμος → βλέπω τον δρόμο. Keep the ν on τον for masculine so it never sounds neuter; feminine την keeps ν only before vowels and hard stops.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Modern Greek grammar — cases",
          "url": "https://en.wikipedia.org/wiki/Modern_Greek_grammar"
        },
        {
          "title": "Wikipedia: Accusative case",
          "url": "https://en.wikipedia.org/wiki/Accusative_case"
        }
      ],
      "drills": [
        {
          "sentence": "Βλέπω {{answer}} δρόμο.",
          "answer": "τον",
          "translation": "I see the street.",
          "transliteration": "Vlépo ___ drómo.",
          "hint": "masculine object — keeps its ν",
          "display_order": 1,
          "cell": "τον"
        },
        {
          "sentence": "Βλέπω {{answer}} πόρτα.",
          "answer": "την",
          "translation": "I see the door.",
          "transliteration": "Vlépo ___ pórta.",
          "hint": "feminine object — ν stays before π",
          "display_order": 2,
          "cell": "την"
        },
        {
          "sentence": "Ακούω {{answer}} παιδί.",
          "answer": "το",
          "translation": "I hear the child.",
          "transliteration": "Akúo ___ pedí.",
          "hint": "neuter — unchanged as object",
          "display_order": 3,
          "cell": "το"
        },
        {
          "sentence": "Αγαπώ {{answer}} θάλασσα.",
          "answer": "τη",
          "translation": "I love the sea.",
          "transliteration": "Agapó ___ thálasa.",
          "hint": "feminine — the ν drops before θ",
          "display_order": 4,
          "cell": "την"
        },
        {
          "sentence": "Διαβάζω {{answer}} βιβλίο.",
          "answer": "το",
          "translation": "I am reading the book.",
          "transliteration": "Diavázo ___ vivlío.",
          "hint": "neuter — unchanged as object",
          "display_order": 5,
          "cell": "το"
        },
        {
          "sentence": "Ρωτάω {{answer}} δάσκαλο.",
