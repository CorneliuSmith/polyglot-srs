    {
      "title": "Gender and number of nouns",
      "level": "A1",
      "function": "Name people and things, one or many",
      "source": "contributor",
      "reviewed": true,
      "display_order": 2,
      "explanation": "Three genders, visible in the endings: masculine -ος (ο δρόμος), feminine -α/-η (η μέρα, η αγάπη), neuter -ο/-ι (το βιβλίο, το παιδί). Plurals: -ος → -οι, -α/-η → -ες, -ο → -α, -ι → -ιά (βιβλίο → βιβλία, παιδί → παιδιά).",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Modern Greek grammar — nouns",
          "url": "https://en.wikipedia.org/wiki/Modern_Greek_grammar"
        },
        {
          "title": "Wikipedia: Grammatical gender",
          "url": "https://en.wikipedia.org/wiki/Grammatical_gender"
        }
      ],
      "drills": [
        {
          "sentence": "Έχω δύο {{answer}}.",
          "answer": "βιβλία",
          "translation": "I have two books.",
          "transliteration": "Ého dío ___.",
          "hint": "book, plural — neuter",
          "display_order": 1,
          "cell": "neuter"
        },
        {
