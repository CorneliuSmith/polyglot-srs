          "answer": "αδελφές",
          "translation": "I have three sisters.",
          "transliteration": "Ého tris ___.",
          "hint": "sister, plural — feminine",
          "display_order": 3,
          "cell": "feminine"
        },
        {
          "sentence": "Οι {{answer}} είναι ωραίοι.",
          "answer": "δρόμοι",
          "translation": "The streets are nice.",
          "transliteration": "I ___ íne oréi.",
          "hint": "street, plural — masculine",
          "display_order": 4,
          "cell": "masculine"
        },
        {
          "sentence": "Έχω δύο {{answer}} στο σπίτι.",
          "answer": "γάτες",
          "translation": "I have two cats at home.",
          "transliteration": "Ého dío ___ sto spíti.",
          "hint": "cat, plural — feminine",
