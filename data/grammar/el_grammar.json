    {
      "title": "Subject pronouns (εγώ, εσύ, αυτός…)",
      "level": "A1",
      "function": "Say who you are talking about — when it needs saying",
      "source": "contributor",
      "reviewed": true,
      "display_order": 1,
      "explanation": "Εγώ (I), εσύ (you), αυτός/αυτή/αυτό (he/she/it), εμείς (we), εσείς (you all — also the polite singular), αυτοί/αυτές/αυτά (they). The verb ending names the person, so Greek drops the pronoun except for emphasis: μιλάω ελληνικά.",
      "culture_note": "Εσείς is both plural and polite — like French vous. Greeks switch to εσύ quickly among peers.",
      "references": [
        {
          "title": "Wikipedia: Modern Greek grammar",
          "url": "https://en.wikipedia.org/wiki/Modern_Greek_grammar"
        },
        {
          "title": "Wikipedia: Pro-drop language",
          "url": "https://en.wikipedia.org/wiki/Pro-drop_language"
        }
      ],
      "drills": [
