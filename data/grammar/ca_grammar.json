    {
      "title": "Gender and number of nouns",
      "level": "A1",
      "function": "Name people and things, one or many",
      "source": "contributor",
      "reviewed": true,
      "display_order": 2,
      "explanation": "Nouns are masculine or feminine; feminines often end in -a (casa), masculines in a consonant or -e (llibre, gat). Plural adds -s, with -a becoming -es (casa → cases). Watch the spelling shifts that keep pronunciation: plaça → places.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Catalan grammar — nouns",
          "url": "https://en.wikipedia.org/wiki/Catalan_grammar"
        },
        {
          "title": "Wikipedia: Grammatical gender",
          "url": "https://en.wikipedia.org/wiki/Grammatical_gender"
        }
      ],
      "drills": [
        {
          "sentence": "Tinc dos {{answer}}.",
          "answer": "llibres",
          "translation": "I have two books.",
          "hint": "book, plural",
          "display_order": 1,
          "cell": "masculine"
        },
        {
          "sentence": "Les {{answer}} són boniques.",
          "answer": "cases",
          "translation": "The houses are beautiful.",
          "hint": "house, plural (-a → -es)",
          "display_order": 2,
          "cell": "feminine"
        },
        {
          "sentence": "Tinc tres {{answer}}.",
          "answer": "germanes",
          "translation": "I have three sisters.",
          "hint": "sister, plural",
          "display_order": 3,
          "cell": "feminine"
        },
        {
          "sentence": "Els {{answer}} són grans.",
          "answer": "jardins",
          "translation": "The gardens are big.",
          "hint": "garden, plural",
          "display_order": 4,
          "cell": "masculine"
        },
        {
          "sentence": "Tinc dos {{answer}} a casa.",
          "answer": "gats",
          "translation": "I have two cats at home.",
          "hint": "cat, plural",
          "display_order": 5,
          "cell": "masculine"
        },
        {
          "sentence": "Les {{answer}} són noves.",
          "answer": "cadires",
          "translation": "The chairs are new.",
          "hint": "chair, plural",
          "display_order": 6,
          "cell": "feminine"
        }
      ],
      "paradigm": [
        "masculine",
        "feminine"
      ]
    },
    {
      "title": "Definite articles (el / la / els / les)",
      "level": "A1",
      "function": "Point to a specific thing",
      "source": "contributor",
      "reviewed": true,
      "display_order": 3,
      "explanation": "El (masculine), la (feminine), els and les in the plural. Before a vowel both singulars become l' (l'amic, l'escola). Catalan even puts an article before people's names in speech: la Maria, en Joan.",
      "culture_note": "The 'personal article' (en/na or el/la before names) is a very Catalan touch — la Núria arriba demà.",
      "references": [
        {
          "title": "Wikipedia: Catalan grammar — articles",
          "url": "https://en.wikipedia.org/wiki/Catalan_grammar"
        },
        {
          "title": "Wiktionary: el (Catalan)",
          "url": "https://en.wiktionary.org/wiki/el#Catalan"
        }
      ],
      "drills": [
        {
          "sentence": "{{answer}} casa és gran.",
          "answer": "La",
          "translation": "The house is big.",
          "hint": "feminine singular",
          "display_order": 1,
          "cell": "la"
        },
        {
          "sentence": "{{answer}} llibre és nou.",
          "answer": "El",
          "translation": "The book is new.",
          "hint": "masculine singular",
          "display_order": 2,
          "cell": "el"
        },
        {
          "sentence": "{{answer}} nens juguen fora.",
          "answer": "Els",
          "translation": "The children are playing outside.",
          "hint": "masculine plural",
          "display_order": 3,
          "cell": "els"
        },
        {
          "sentence": "{{answer}} cafè és calent.",
          "answer": "El",
          "translation": "The coffee is hot.",
          "hint": "masculine singular",
          "display_order": 4,
          "cell": "el"
        },
        {
          "sentence": "{{answer}} porta és oberta.",
          "answer": "La",
          "translation": "The door is open.",
          "hint": "feminine singular",
          "display_order": 5,
          "cell": "la"
        },
        {
          "sentence": "{{answer}} noies són simpàtiques.",
          "answer": "Les",
          "translation": "The girls are nice.",
          "hint": "feminine plural",
          "display_order": 6,
          "cell": "les"
        },
        {
          "sentence": "{{answer}} gats dormen al sofà.",
          "answer": "Els",
          "translation": "The cats sleep on the sofa.",
          "hint": "the — masculine plural",
          "cell": "els",
          "display_order": 7
        },
        {
          "sentence": "{{answer}} finestres són obertes.",
          "answer": "Les",
          "translation": "The windows are open.",
          "hint": "the — feminine plural",
          "cell": "les",
          "display_order": 8
        }
      ],
      "paradigm": [
        "el",
        "la",
        "els",
        "les"
      ]
    },
    {
      "title": "Indefinite articles (un / una)",
      "level": "A1",
      "function": "Mention something for the first time",
      "source": "contributor",
      "reviewed": true,
      "display_order": 4,
      "explanation": "Un for masculine (un gos), una for feminine (una casa). The plurals uns/unes mean 'some': uns amics. No elision here — una idea keeps its article whole.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Catalan grammar — articles",
          "url": "https://en.wikipedia.org/wiki/Catalan_grammar"
        },
        {
