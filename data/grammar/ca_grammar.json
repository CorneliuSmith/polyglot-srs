          "display_order": 15
        },
        {
          "sentence": "{{answer}} arriben demà.",
          "answer": "Elles",
          "translation": "They (f.) arrive tomorrow.",
          "hint": "they (feminine)",
          "cell": "elles",
          "display_order": 16
        }
      ],
      "paradigm": [
