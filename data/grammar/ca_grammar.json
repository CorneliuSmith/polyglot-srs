  "points": [
    {
      "title": "Subject pronouns (jo, tu, ell…)",
      "level": "A1",
      "function": "Say who you are talking about — when it needs saying",
      "source": "contributor",
      "reviewed": true,
      "display_order": 1,
      "explanation": "Jo (I), tu (you, informal), ell/ella (he/she), vostè (you, formal), nosaltres (we), vosaltres (you all), ells/elles (they). The verb ending already names the person, so Catalan usually drops the pronoun — parlo català — and uses it only for emphasis or contrast.",
      "culture_note": "Vostè takes third-person verb forms, like Spanish usted — but Catalans reach for it less often than Spaniards do.",
      "references": [
        {
          "title": "Wikipedia: Catalan grammar",
          "url": "https://en.wikipedia.org/wiki/Catalan_grammar"
        },
        {
          "title": "Wikipedia: Pro-drop language",
          "url": "https://en.wikipedia.org/wiki/Pro-drop_language"
        }
      ],
      "drills": [
        {
          "sentence": "{{answer}} soc de Barcelona.",
          "answer": "Jo",
          "translation": "I am from Barcelona.",
          "hint": "I",
          "display_order": 1,
          "cell": "jo"
        },
        {
          "sentence": "{{answer}} ets el meu amic.",
          "answer": "Tu",
          "translation": "You are my friend.",
          "hint": "you — informal",
          "display_order": 2,
          "cell": "tu"
        },
        {
          "sentence": "{{answer}} és la meva germana.",
          "answer": "Ella",
          "translation": "She is my sister.",
          "hint": "she",
          "display_order": 3,
          "cell": "ella"
        },
        {
          "sentence": "{{answer}} som estudiants.",
          "answer": "Nosaltres",
          "translation": "We are students.",
          "hint": "we",
          "display_order": 4,
          "cell": "nosaltres"
        },
        {
          "sentence": "{{answer}} són de Girona.",
          "answer": "Ells",
          "translation": "They are from Girona.",
          "hint": "they (masculine)",
          "display_order": 5,
          "cell": "ells"
        },
        {
          "sentence": "{{answer}} sou molt amables.",
          "answer": "Vosaltres",
          "translation": "You (all) are very kind.",
          "hint": "you — plural",
          "display_order": 6,
          "cell": "vosaltres"
        },
        {
          "sentence": "{{answer}} és el meu germà.",
          "answer": "Ell",
          "translation": "He is my brother.",
          "hint": "he",
          "cell": "ell",
          "display_order": 7
        },
        {
          "sentence": "{{answer}} són les meves amigues.",
          "answer": "Elles",
          "translation": "They are my friends (all women).",
          "hint": "they — all female",
          "cell": "elles",
          "display_order": 8
        },
        {
          "sentence": "{{answer}} parlo una mica de català.",
          "answer": "Jo",
          "translation": "I speak a little Catalan.",
          "hint": "I",
          "cell": "jo",
          "display_order": 9
        },
        {
          "sentence": "{{answer}} vius aquí a prop?",
          "answer": "Tu",
          "translation": "Do you live near here?",
          "hint": "you — informal",
          "cell": "tu",
          "display_order": 10
        },
        {
          "sentence": "{{answer}} treballa en un banc.",
          "answer": "Ell",
          "translation": "He works in a bank.",
          "hint": "he",
          "cell": "ell",
          "display_order": 11
        },
        {
          "sentence": "{{answer}} canta molt bé.",
          "answer": "Ella",
          "translation": "She sings very well.",
          "hint": "she",
          "cell": "ella",
          "display_order": 12
        },
        {
          "sentence": "{{answer}} vivim a Girona.",
          "answer": "Nosaltres",
          "translation": "We live in Girona.",
          "hint": "we",
          "cell": "nosaltres",
          "display_order": 13
        },
        {
          "sentence": "{{answer}} parleu anglès?",
          "answer": "Vosaltres",
          "translation": "Do you (all) speak English?",
