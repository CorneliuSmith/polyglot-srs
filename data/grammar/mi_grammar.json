    {
      "title": "Ko — naming and identifying",
      "level": "A1",
      "function": "Name a specific person, place, or thing",
      "source": "contributor",
      "reviewed": true,
      "display_order": 4,
      "explanation": "Ko identifies a SPECIFIC one: Ko Mere tēnei (This is Mere), Ko wai tō ingoa? (What is your name?). Use ko with names and definite nouns; use he to classify. Compare: He kaiako ia (she's a teacher — one of many) vs Ko ia te kaiako (she is THE teacher).",
      "culture_note": "Ko opens the mihi (introduction): Ko Aoraki te maunga, ko Waitaki te awa… — naming your mountain and river before yourself.",
      "references": [
        {
          "title": "Wikipedia: Māori language — grammar",
          "url": "https://en.wikipedia.org/wiki/M%C4%81ori_language"
        },
        {
          "title": "Te Aka Māori Dictionary: ko",
          "url": "https://maoridictionary.co.nz/search?keywords=ko"
        }
      ],
      "drills": [
        {
          "sentence": "{{answer}} Mere tēnei.",
          "answer": "Ko",
          "translation": "This is Mere.",
          "hint": "the identifying particle",
          "display_order": 1
        },
        {
          "sentence": "{{answer}} wai tō ingoa?",
          "answer": "Ko",
          "translation": "What is your name?",
          "hint": "the identifying particle",
          "display_order": 2
        },
        {
          "sentence": "{{answer}} Tāmaki Makaurau tēnei tāone.",
          "answer": "Ko",
          "translation": "This city is Auckland.",
          "hint": "the identifying particle",
          "display_order": 3
        },
        {
          "sentence": "{{answer}} ia te kaiako.",
          "answer": "Ko",
          "translation": "She is the teacher.",
          "hint": "the identifying particle",
          "display_order": 4
        },
        {
          "sentence": "{{answer}} Hemi au.",
          "answer": "Ko",
          "translation": "I am Hemi.",
          "hint": "the identifying particle",
          "display_order": 5
        },
        {
          "sentence": "{{answer}} tērā te kura.",
          "answer": "Ko",
          "translation": "That is the school.",
          "hint": "the identifying particle",
          "display_order": 6
        }
      ]
    },
    {
      "title": "Kei te — happening now",
      "level": "A1",
      "function": "Say what is happening right now",
      "source": "contributor",
      "reviewed": true,
      "display_order": 5,
      "explanation": "Kei te + verb marks the present: Kei te kai au (I am eating), Kei te ako mātou (we are learning). The greeting Kei te pēhea koe? (How are you?) lives on this pattern — Kei te pai (I'm good).",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Māori language — grammar",
          "url": "https://en.wikipedia.org/wiki/M%C4%81ori_language"
        },
        {
          "title": "Te Aka Māori Dictionary: kei te",
          "url": "https://maoridictionary.co.nz/search?keywords=kei+te"
        }
      ],
      "drills": [
        {
          "sentence": "{{answer}} te kai au.",
          "answer": "Kei",
