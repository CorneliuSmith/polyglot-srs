    {
      "title": "Possession: the a and o categories",
      "level": "A1",
      "function": "Say whose something is — the Māori way",
      "source": "contributor",
      "reviewed": true,
      "display_order": 11,
      "explanation": "Māori splits possession in two: Ā-category for things you control or made (tāku pukapuka — my book, tāu mahi — your work) and Ō-category for things you don't control — houses, vehicles, friends, body parts (tōku whare, tō waka, tōku hoa). Same owner, different vowel.",
      "culture_note": "The a/o split encodes a worldview: your ancestors, your land, and your friends are ō — they are not possessions you command.",
      "references": [
        {
          "title": "Wikipedia: Māori language — grammar",
          "url": "https://en.wikipedia.org/wiki/M%C4%81ori_language"
        },
        {
          "title": "Te Aka Māori Dictionary: tōku",
          "url": "https://maoridictionary.co.nz/search?keywords=t%C5%8Dku"
        }
      ],
      "drills": [
        {
          "sentence": "Ko {{answer}} whare tēnei.",
          "answer": "tōku",
          "translation": "This is my house.",
          "hint": "my — o category (not controlled)",
          "display_order": 1
        },
        {
          "sentence": "Ko {{answer}} pukapuka tēnā.",
          "answer": "tāku",
          "translation": "That is my book.",
          "hint": "my — a category (controlled)",
          "display_order": 2
        },
        {
          "sentence": "Kei hea {{answer}} waka?",
          "answer": "tō",
          "translation": "Where is your car?",
          "hint": "your — o category",
          "display_order": 3
        },
        {
          "sentence": "He pai {{answer}} mahi.",
          "answer": "tāu",
          "translation": "Your work is good.",
          "hint": "your — a category",
          "display_order": 4
        },
        {
          "sentence": "Ko ia {{answer}} hoa.",
          "answer": "tōku",
          "translation": "He is my friend.",
          "hint": "my — friends are o category",
          "display_order": 5
        },
        {
          "sentence": "He reka {{answer}} kai.",
          "answer": "tāku",
          "translation": "My food is delicious.",
          "hint": "my — a category",
          "display_order": 6
        }
      ]
    },
    {
      "title": "Statives (he nui, he pai)",
      "level": "A1",
      "function": "Describe people and things",
      "source": "contributor",
      "reviewed": true,
      "display_order": 12,
      "explanation": "Describing words work like the he-sentence: He nui te whare (The house is big), He pai tēnei pukapuka (This book is good). No 'to be', no agreement — the stative leads and the thing described follows.",
      "culture_note": "",
