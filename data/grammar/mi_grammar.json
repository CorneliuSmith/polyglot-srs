{
  "lists": [
    {
      "level": "A1",
      "title": "Māori A1 Grammar Path",
      "description": "A1 grammar in communicative order: pronouns, te and ngā, the sentence types he and ko, the tense-aspect particles kei te / i / ka, location with kei, negation with kāore, questions, and the a/o categories of possession."
    }
