  "points": [
    {
      "title": "Pronouns (au, koe, ia…)",
      "level": "A1",
      "function": "Say who you are talking about",
      "source": "contributor",
      "reviewed": true,
      "display_order": 1,
      "explanation": "Au (I), koe (you, one person), ia (he or she — no gender!), mātou (we, NOT including you), tātou (we, including you), koutou (you, three or more), rātou (they). Māori marks whether 'we' includes the listener — a distinction English never makes.",
      "culture_note": "Choosing tātou over mātou is an act of inclusion — 'Tēnā koutou, tēnā tātou katoa' welcomes everyone into the 'we'.",
      "references": [
        {
          "title": "Wikipedia: Māori language — grammar",
          "url": "https://en.wikipedia.org/wiki/M%C4%81ori_language"
        },
        {
          "title": "Te Aka Māori Dictionary",
          "url": "https://maoridictionary.co.nz/"
        }
      ],
      "drills": [
        {
          "sentence": "He tauira {{answer}}.",
          "answer": "au",
          "translation": "I am a student.",
          "hint": "I",
          "display_order": 1
        },
        {
          "sentence": "Kei te pēhea {{answer}}?",
          "answer": "koe",
          "translation": "How are you?",
          "hint": "you — one person",
          "display_order": 2
        },
        {
          "sentence": "He kaiako {{answer}}.",
          "answer": "ia",
          "translation": "She is a teacher.",
          "hint": "he or she — no gender",
          "display_order": 3
        },
        {
          "sentence": "Kei te ako {{answer}} i te reo.",
          "answer": "mātou",
          "translation": "We are learning the language.",
          "hint": "we — not including you",
          "display_order": 4
        },
        {
          "sentence": "Kei te haere {{answer}} ki te kura.",
          "answer": "rātou",
          "translation": "They are going to school.",
          "hint": "they — three or more",
          "display_order": 5
        },
        {
          "sentence": "E noho ana {{answer}} ki Pōneke.",
          "answer": "koutou",
          "translation": "You (all) live in Wellington.",
          "hint": "you — three or more",
          "display_order": 6
        }
      ]
    },
    {
      "title": "Te and ngā — the articles",
      "level": "A1",
      "function": "Point to one thing or many",
      "source": "contributor",
      "reviewed": true,
      "display_order": 2,
      "explanation": "Nouns don't change for plural — the article does the work: te whare (the house), ngā whare (the houses). This one contrast carries all of Māori number. He (a/some) is the indefinite and gets its own point next.",
      "culture_note": "",
      "references": [
        {
          "title": "Wikipedia: Māori language — grammar",
          "url": "https://en.wikipedia.org/wiki/M%C4%81ori_language"
        },
        {
          "title": "Te Aka Māori Dictionary: te",
          "url": "https://maoridictionary.co.nz/search?keywords=te"
        }
      ],
      "drills": [
