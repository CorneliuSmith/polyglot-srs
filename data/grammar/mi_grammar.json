          "answer": "te",
          "translation": "The food is good.",
          "hint": "one thing",
          "display_order": 2
        },
        {
          "sentence": "Kei te tākaro {{answer}} tamariki.",
          "answer": "ngā",
          "translation": "The children are playing.",
          "hint": "more than one",
          "display_order": 3
        },
        {
          "sentence": "He reka {{answer}} āporo.",
          "answer": "ngā",
          "translation": "The apples are sweet.",
          "hint": "more than one",
          "display_order": 4
        },
        {
          "sentence": "Kei konei {{answer}} pukapuka.",
          "answer": "te",
          "translation": "The book is here.",
          "hint": "one thing",
          "display_order": 5
        },
        {
          "sentence": "He hou {{answer}} waka.",
          "answer": "te",
