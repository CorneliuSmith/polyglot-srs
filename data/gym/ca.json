          "label": "Present -re/-ir",
          "usage": "Now or regularly, -re and -ir verbs.",
          "example": "Llegeixo un llibre."
        },
        {
          "point": "The past (passat perifràstic: vaig anar)",
          "label": "Past (perifràstic)",
          "usage": "The finished past: vaig + infinitive.",
          "example": "Ahir vaig parlar."
        },
        {
          "point": "The imperfect (l'imperfet)",
          "label": "Imperfect",
          "usage": "The ongoing or habitual past.",
          "example": "De petit jugava molt."
        },
        {
          "point": "The future (el futur)",
          "label": "Future",
          "usage": "What will happen.",
          "example": "Demà menjaré tard."
        },
        {
          "point": "The conditional (el condicional)",
          "label": "Conditional",
          "usage": "What would happen.",
          "example": "Voldria marxar."
        },
        {
          "point": "The subjunctive (el subjuntiu)",
          "label": "Subjunctive",
          "usage": "After que — wish, doubt.",
          "example": "Espero que vinguis."
        },
        {
          "point": "The imperative (parla! no parlis!)",
          "label": "Imperative",
          "usage": "Commands.",
          "example": "Parla més fort!"
        }
      ]
    },
    {
      "kind": "agreement",
      "label": "Agreement",
      "entries": [
        {
          "point": "Definite articles (el / la / els / les)",
          "label": "Definite article",
          "usage": "el/la/els/les.",
          "example": "el llibre, les cases"
        },
        {
          "point": "Indefinite articles (un / una)",
          "label": "Indefinite article",
          "usage": "un/una/uns/unes.",
          "example": "un cotxe, una taula"
        },
        {
          "point": "Adjective agreement",
          "label": "Adjectives",
          "usage": "Adjectives match gender and number.",
