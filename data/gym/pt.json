          "usage": "Now or regularly, -er and -ir verbs.",
          "example": "Como pão e abro a porta."
        },
        {
          "point": "The past — pretérito perfeito (falei, comeu)",
          "label": "Pretérito perfeito",
          "usage": "A finished past action.",
          "example": "Ontem falei com ela."
        },
        {
          "point": "The imperfect (falava, comia)",
          "label": "Imperfect",
          "usage": "The ongoing or habitual past.",
          "example": "Quando era criança, falava muito."
        },
        {
          "point": "The future with ir (vou falar)",
          "label": "Future (ir)",
          "usage": "What will happen: ir + infinitive.",
          "example": "Amanhã vou comer tarde."
        },
        {
          "point": "The conditional (falaria, gostaria)",
          "label": "Conditional",
          "usage": "What would happen.",
          "example": "Eu gostaria de viajar."
        },
        {
          "point": "Presente do subjuntivo (que eu fale)",
          "label": "Subjunctive",
          "usage": "After que — wish, doubt, request.",
          "example": "Espero que você fale."
        },
        {
          "point": "Imperfeito do subjuntivo (se eu falasse)",
          "label": "Past subjunctive",
          "usage": "Hypotheticals: se eu falasse…",
          "example": "Se eu falasse, entenderia."
        },
        {
          "point": "The imperative (fala! / fale!)",
          "label": "Imperative",
          "usage": "Commands.",
          "example": "Fala mais alto!"
        },
        {
          "point": "Right now: estar + -ndo (estou falando)",
          "label": "Progressive",
          "usage": "Happening right now.",
          "example": "Estou comendo agora."
        },
        {
          "point": "Key irregular presents (vou, faço, posso, quero)",
          "label": "Irregular presents",
          "usage": "The common irregular present forms.",
          "example": "Vou ao centro e faço tudo.",
          "nonstandard": true
        },
        {
          "point": "Pretérito perfeito — irregulares (fui, fiz, tive)",
          "label": "Irregular preterites",
