        },
        {
          "point": "Articulated prepositions (del, al, nel, sul…)",
          "label": "Articulated prepositions",
          "usage": "preposition + article fused.",
          "example": "del pane, nel bosco"
        },
        {
          "point": "Possessives & demonstratives (il mio, questo…)",
          "label": "Possessive/demonstrative",
          "usage": "il mio, questo/quello.",
