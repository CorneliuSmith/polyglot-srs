        {
          "point": "-ere and -ire verbs (prendere, dormire, finire)",
          "label": "Present -ere/-ire",
          "usage": "Now or regularly, -ere and -ire verbs.",
          "example": "Prendo il treno."
        },
        {
          "point": "Passato prossimo with avere",
          "label": "Passato prossimo (avere)",
          "usage": "A finished past with avere.",
          "example": "Ho mangiato una mela."
        },
        {
          "point": "Passato prossimo with essere",
          "label": "Passato prossimo (essere)",
          "usage": "Past with essere — motion and reflexives.",
          "example": "È partita presto."
        },
        {
          "point": "The imperfect (l'imperfetto)",
          "label": "Imperfect",
          "usage": "The ongoing or habitual past.",
          "example": "Giocavo sempre."
        },
        {
          "point": "The future (il futuro semplice)",
          "label": "Future",
          "usage": "What will happen.",
          "example": "Domani mangerò tardi."
        },
        {
          "point": "The conditional (il condizionale)",
          "label": "Conditional",
          "usage": "What would happen.",
          "example": "Vorrei partire."
        },
        {
          "point": "The subjunctive (il congiuntivo)",
          "label": "Subjunctive",
          "usage": "After che — wish, doubt, opinion.",
          "example": "Penso che tu venga."
        },
        {
          "point": "The imperative (parla! non parlare!)",
          "label": "Imperative",
          "usage": "Commands.",
          "example": "Parla più forte!"
        },
        {
          "point": "Stare + gerundio (sto mangiando)",
          "label": "Progressive",
          "usage": "Happening right now.",
          "example": "Sto mangiando adesso."
        }
      ]
    },
    {
      "kind": "agreement",
      "label": "Agreement",
      "entries": [
        {
          "point": "Definite articles (il / la / i / le)",
          "label": "Definite article",
