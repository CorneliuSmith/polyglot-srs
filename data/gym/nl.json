        {
          "point": "Zijn — present (ben, bent, is, zijn)",
          "label": "zijn (present)",
          "usage": "'to be'.",
          "example": "Ik ben moe."
        },
        {
          "point": "Hebben — present (heb, hebt, heeft)",
          "label": "hebben (present)",
          "usage": "'to have'.",
          "example": "Ik heb tijd."
        },
        {
          "point": "The perfect: heb gewerkt, ben gegaan",
          "label": "Perfect",
          "usage": "Finished past with hebben/zijn.",
          "example": "Ik heb gewerkt."
        },
        {
          "point": "Imperfect: werkte, speelde",
          "label": "Imperfect",
          "usage": "The narrative/written past.",
          "example": "Ik speelde vaak buiten."
        },
        {
          "point": "Future: gaan + infinitive, zullen",
          "label": "Future",
          "usage": "What will happen.",
          "example": "Ik ga morgen komen."
        },
        {
          "point": "Modal verbs: kunnen, moeten, mogen, willen",
          "label": "Modal verbs",
          "usage": "can/must/may/want + infinitive.",
          "example": "Ik kan zwemmen."
        },
        {
          "point": "The imperative",
          "label": "Imperative",
          "usage": "Commands.",
          "example": "Kom hier!"
        },
        {
          "point": "Progressive: aan het + infinitive, zitten te",
          "label": "Progressive",
          "usage": "Happening right now.",
          "example": "Ik ben aan het eten."
        },
        {
          "point": "Separable verbs: opstaan → ik sta op",
          "label": "Separable verbs",
          "usage": "The prefix splits off to the end.",
          "example": "Ik sta om zeven uur op.",
          "nonstandard": true
        }
      ]
    },
    {
      "kind": "agreement",
      "label": "Agreement",
      "entries": [
        {
          "point": "De and het: the two genders",
          "label": "De / het",
          "usage": "The two article genders.",
          "example": "de man, het huis"
        },
        {
          "point": "Adjectives: the -e rule",
          "label": "Adjective -e",
          "usage": "When the adjective takes -e.",
          "example": "een rode auto, het rode huis"
        },
        {
          "point": "Plurals: -en and -s",
          "label": "Plurals",
          "usage": "Noun plural forms.",
          "example": "boek → boeken, auto → auto's"
