        {
          "point": "Possessives: mijn, jouw, zijn, haar…",
          "label": "Possessives",
          "usage": "my/your/his/her.",
          "example": "mijn broer, haar boek"
        },
        {
          "point": "Comparative and superlative: -er, -st",
          "label": "Comparative",
          "usage": "-er / -st.",
          "example": "groot → groter → grootst"
        },
        {
          "point": "Diminutives: -je, -tje, -pje",
          "label": "Diminutives",
          "usage": "The -je ending (little / cute).",
