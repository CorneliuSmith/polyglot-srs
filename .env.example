# =============================================================================
#  PolyglotSRS — backend environment sample
#  Copy to `.env` (cp .env.example .env) and fill in. The backend reads `.env`;
#  the frontend has its own sample at frontend/.env.example.
#  Only the values under REQUIRED must be set — everything else has a sensible
#  default and can stay commented out. Recommended values are shown.
# =============================================================================

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Supabase project URL (Settings > API).
SUPABASE_URL=https://your-project.supabase.co

# JWT secret for legacy HS256 tokens (Settings > API > JWT keys). Required
# while HS256 tokens are issued; asymmetric (ES256/RS256) tokens use the JWKS.
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Direct Postgres connection (Settings > Database > Connection string).
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# App environment: development | staging | production
ENVIRONMENT=development

# Comma-separated CORS origins allowed to call the API (JSON array).
CORS_ORIGINS=["http://localhost:5173"]

# The backend does NOT use the anon/service_role keys — it reaches Postgres
# directly and verifies tokens with the JWT secret / JWKS. Kept here only so a
# single .env can also feed Supabase CLI tooling. Safe to leave blank.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
#  AI — Anthropic (Claude) key + per-task model selection
# =============================================================================
#
# Nothing below costs anything until ANTHROPIC_API_KEY is set: every AI feature
# no-ops or falls back when it's blank. The core app (reviews, learn, decks,
# Gym drilling seeded content) runs with NO key.
#
# List prices (USD per million tokens; cache reads = 10% of input):
#   claude-opus-4-8 / claude-fable-5 ..... $5 in  / $25 out   (strongest)
#   claude-sonnet-5 / claude-sonnet-4-6 .. $3 in  / $15 out   (default workhorse)
#   claude-haiku-4-5-20251001 ............ $1 in  / $5  out   (mechanical work)
#
# Rough per-action cost: a tutor message ~= $0.005-0.02 (charter is cache-read),
# a Reader text ~= $0.02-0.05, an AI grammar check ~= $0.01-0.03. Batch
# generation of a 40-point language path ~= $2-6. The app logs REAL per-turn
# cost to the tutor_usage table (admin "Tutor costs" panel) once the key is set.

# Anthropic API key (https://console.anthropic.com — includes starter credits).
# Leave blank to disable all AI features, OR set TUTOR_DEV_MOCK=true below to
# click through the tutor with no key and no cost.
ANTHROPIC_API_KEY=

# ── Model per task (RUNTIME) ────────────────────────────────────────────────
# These three env vars drive every runtime AI task. Defaults shown are the
# recommended values (they match config.py); uncomment only to override.

# Tutor CHAT (also used by the Reader). Recommended: Sonnet — scaffolded
# coaching at ~40% of Opus cost. (The tutor is the main cost driver.)
# TUTOR_MODEL=claude-sonnet-5

# Tutor chat for LOW-RESOURCE languages (mi, sw, yo, ha, xh, ar) — accuracy is
# the differentiator there, so pin the strongest model. A per-language override
# set in the admin UI (Contribute > Tutor model) always wins over this.
# TUTOR_MODEL_LOW_RESOURCE=claude-opus-4-8

# Off-hot-path work: session summarizer / memory extractor AND the contributor
# "Run AI check" grammar review. Recommended: Sonnet (good judgement per dollar).
# TUTOR_SUMMARY_MODEL=claude-sonnet-5

# ── Model per task (BATCH generation — set on the CLI, not here) ────────────
# The seed/generation pipelines take a --model (or --maker-model/--checker-model)
# flag per run instead of an env var. Recommended split (see docs/ROADMAP §6 —
# "never self-certify": the verifier is always one tier above the drafter):
#   AI curriculum gen (WP6) — uses TUTOR_MODEL for drafting + TUTOR_SUMMARY_MODEL
#   for the semantic check (no --model flag); set those env vars for the run:
#     TUTOR_MODEL=claude-opus-4-8 python -m backend.services.seeder.generate_curriculum \
#       --language es --generate
#   Sentence gap-gen (WP5, thin corpora — sw/yo/ha/xh/mi):
#     python -m backend.services.seeder.harvest_sentences --language sw \
#       --model claude-sonnet-5
#   Translation maker/checker:
#     python -m backend.services.seeder.translate_english \
#       --maker-model claude-sonnet-5 --checker-model claude-opus-4-8
# High-resource languages: draft Sonnet -> verify Opus. Low-resource: Opus/Fable
# throughout, plus a human gate.

# ── Tutor access + allowances (cost protection; flat-priced, never per msg) ──
# Dev/testing WITHOUT a key: canned responses, no Claude calls, no cost. Lets
# you exercise chat, the entitlement gate, memory, and the session summary.
# Try `/remember global native_language English` in the chat. NEVER in prod.
TUTOR_DEV_MOCK=true

# Grant every signed-in user tutor access until Stripe entitlements exist.
# Set false in production so entitlements actually govern access.
TUTOR_FREE_ACCESS=true

# Message caps per tier (cost protection, shown openly in the UI). Defaults:
# TUTOR_FREE_MONTHLY_MESSAGES=20
# TUTOR_SINGLE_MONTHLY_MESSAGES=100
# TUTOR_ALL_MONTHLY_MESSAGES=300
# TUTOR_PLUS_DAILY_MESSAGES=50

# =============================================================================
#  Audio — neural TTS (WP7)
# =============================================================================
# Microsoft blocks edge-tts's keyless endpoint from datacenter IPs, so PROD
# needs a real Azure Speech key (free F0 tier covers the beta many times over).
# Empty key = edge-tts, which works from residential IPs (local dev only).
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus

# =============================================================================
#  Error telemetry (WP19d)
# =============================================================================
# Empty DSN disables Sentry entirely.
# SENTRY_DSN=

# =============================================================================
#  Email review reminders (Resend)
# =============================================================================
# Empty key = log-only (nothing sent, nothing marked sent) — safe before the
# mail account exists. RESEND_FROM must be a sender Resend allows.
# RESEND_API_KEY=
# RESEND_FROM=PolyglotSRS <onboarding@resend.dev>
# EMAIL_REMINDERS_ENABLED=true
# APP_URL=https://your-app.ondigitalocean.app

# =============================================================================
#  Rate limiting
# =============================================================================
# Optional Redis for distributed rate limiting across multiple backend workers.
# Empty = in-process limiter (fine for a single worker / dev).
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
#  Billing (Stripe — tutor add-on + language plans)
# =============================================================================
# Leave blank to disable checkout. For a demo WITHOUT Stripe, set
# STRIPE_DEV_MOCK=true and TUTOR_FREE_ACCESS=false — the Subscribe button then
# grants access instantly so you can show the gated -> unlocked flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# STRIPE_PRICE_SINGLE=
# STRIPE_PRICE_ALL=
# STRIPE_DEV_MOCK=false

# Where Stripe Checkout returns the user (your frontend origin).
# APP_BASE_URL=http://localhost:5173
