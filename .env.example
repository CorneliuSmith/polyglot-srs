# Supabase project URL (from Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# NOTE: the backend does NOT use the anon/service_role keys — it connects to
# Postgres directly (DATABASE_URL) and verifies tokens with the JWT secret /
# JWKS. Both are OPTIONAL and can be left blank. They're kept here only so a
# single .env can also feed the frontend and any Supabase CLI tooling.
#
# Supabase is migrating from the legacy anon/service_role keys to new
# "publishable" (sb_publishable_...) and "secret" (sb_secret_...) API keys.
# The legacy keys keep working alongside the new ones until you disable them.
# The frontend only needs the public key (as VITE_SUPABASE_ANON_KEY in
# frontend/.env) — the publishable key is a drop-in for the anon key there.

# Legacy anon key OR the new publishable key (from Settings > API keys). Unused by the backend.
SUPABASE_ANON_KEY=

# Legacy service_role key OR the new secret key (keep secret). Unused by the backend.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for legacy HS256 tokens (Settings > API > JWT keys). Required
# while HS256 tokens are issued; asymmetric signing keys use the JWKS instead.
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Direct PostgreSQL connection string (from Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Application environment: development | staging | production
ENVIRONMENT=development

# Comma-separated CORS origins allowed to call the API
CORS_ORIGINS=["http://localhost:5173"]

# --- AI tutor ---

# Real mode: set an Anthropic API key (https://console.anthropic.com — includes
# starter credits; testing the tutor costs cents). Leave blank to disable the
# tutor, OR turn on dev mock mode below to test it with no key and no cost.
ANTHROPIC_API_KEY=

# Dev/testing WITHOUT a key or any cost. The tutor returns canned responses and
# makes NO Claude API calls, so you can click through the whole feature (chat,
# entitlement gate, memory, session-end summary). In the chat, send
# `/remember global native_language English` to exercise the remember->persist
# path. NEVER enable in production.
TUTOR_DEV_MOCK=true

# Grant every signed-in user tutor access until Stripe entitlements exist.
TUTOR_FREE_ACCESS=true

# Tutor models (override only if needed). Chat runs on Opus; the off-the-hot-path
# session summarizer runs on the cheaper Sonnet.
# TUTOR_MODEL=claude-opus-4-8
# TUTOR_SUMMARY_MODEL=claude-sonnet-4-6

# Optional: Redis for distributed rate limiting across multiple backend workers.
# Leave blank to use the in-process limiter (fine for a single worker / dev).
# REDIS_URL=redis://localhost:6379/0

# --- Billing (Stripe, tutor add-on) ---

# Leave blank to disable checkout. For a demo WITHOUT Stripe, set
# STRIPE_DEV_MOCK=true and TUTOR_FREE_ACCESS=false — the Subscribe button then
# grants tutor access instantly so you can show the gated -> unlocked flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# STRIPE_DEV_MOCK=false

# Where Stripe Checkout returns the user (your frontend origin).
# APP_BASE_URL=http://localhost:5173
