# Supabase project URL (from Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (from Settings > API)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (from Settings > API -- keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT secret (from Settings > API > JWT Settings)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Direct PostgreSQL connection string (from Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Application environment: development | staging | production
ENVIRONMENT=development

# Comma-separated CORS origins allowed to call the API
CORS_ORIGINS=["http://localhost:5173"]

# --- AI tutor ---

# Real mode: set an Anthropic API key (https://console.anthropic.com — includes
# starter credits; testing the tutor costs cents). Leave blank to disable the
# tutor, OR turn on dev mock mode below to test it with no key and no cost.
ANTHROPIC_API_KEY=

# Dev/testing WITHOUT a key or any cost. The tutor returns canned responses and
# makes NO Claude API calls, so you can click through the whole feature (chat,
# entitlement gate, memory, session-end summary). In the chat, send
# `/remember global native_language English` to exercise the remember->persist
# path. NEVER enable in production.
TUTOR_DEV_MOCK=true

# Grant every signed-in user tutor access until Stripe entitlements exist.
TUTOR_FREE_ACCESS=true

# Tutor models (override only if needed). Chat runs on Opus; the off-the-hot-path
# session summarizer runs on the cheaper Sonnet.
# TUTOR_MODEL=claude-opus-4-8
# TUTOR_SUMMARY_MODEL=claude-sonnet-4-6

# Optional: Redis for distributed rate limiting across multiple backend workers.
# Leave blank to use the in-process limiter (fine for a single worker / dev).
# REDIS_URL=redis://localhost:6379/0
