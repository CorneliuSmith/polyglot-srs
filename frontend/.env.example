# Frontend environment (Vite). Copy to frontend/.env.local and fill in.

# Supabase project URL and anon/public key (Settings > API). Must be the same
# Supabase project the backend points at.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Base URL of the backend API. Leave blank to call the same origin (e.g. behind
# a dev proxy); set to the backend URL otherwise.
VITE_API_BASE_URL=http://localhost:8000

# Private beta: hides self-serve Sign Up + Google on the login page.
# ENFORCEMENT is in Supabase (Auth -> disable signups + Google provider).
VITE_INVITE_ONLY=true

# Optional: Sentry DSN for frontend error telemetry. Empty = disabled.
# VITE_SENTRY_DSN=
