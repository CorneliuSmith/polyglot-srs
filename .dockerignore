# The image serves the API only — content data lives in Supabase already
# (seeding runs from a dev machine), and the frontend deploys separately
# as a static site.
.git
.venv
node_modules
frontend
# Exclude the seed corpora but KEEP data/gym — the API serves the Gym
# manifests from disk at runtime, so they must be in the image. (Excluding
# all of data/ silently made COPY data/gym a no-op: the Gym shipped empty.)
data/*
!data/gym
docs
scripts
supabase
scratchpad
**/__pycache__
**/*.pyc
.env
.env.*
